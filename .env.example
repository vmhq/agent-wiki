# ─────────────────────────────────────────────────────────────────────────────
# Agent Wiki — environment variables
#
# Copy this file to .env and fill in the values marked with CHANGE THIS.
# Variables marked OPTIONAL can be left at their defaults for local dev.
#
#   cp .env.example .env
#
# Generate a secure random string (for WIKI_API_KEY, WIKI_JWT_SECRET):
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────


# ── Storage ───────────────────────────────────────────────────────────────────

# Absolute path to the directory that stores wiki .md files.
# In Docker this is the volume mount point. Locally it defaults to
# the repo-root wiki/ directory when unset.
WIKI_DIR=/wiki


# ── MCP server authentication ─────────────────────────────────────────────────

# API key for simple token auth — pass as:
#   Authorization: Bearer <WIKI_API_KEY>
# Used by Claude Desktop and scripts. CHANGE THIS.
WIKI_API_KEY=changeme

# Password shown on the OAuth consent page when a user authorizes a client
# (e.g. claude.ai). CHANGE THIS.
WIKI_OAUTH_PASSWORD=changeme

# Secret used to sign and verify JWT access tokens.
# Must be a long random string. CHANGE THIS in production.
# Generate: openssl rand -hex 32
WIKI_JWT_SECRET=change-this-to-a-random-string-in-production

# Client secret for the pre-registered "agent-wiki-local" OAuth client.
# Only relevant if you use OAuth instead of the API key. OPTIONAL.
WIKI_CLIENT_SECRET=local-secret


# ── MCP server network ────────────────────────────────────────────────────────

# Public base URL of the MCP server. Included in OAuth metadata so that
# clients can discover the authorization and token endpoints.
# Change to your public hostname/IP when deploying to a server.
MCP_BASE_URL=http://localhost:3001

# Host port for the MCP server container. OPTIONAL.
MCP_PORT=3001


# ── Web app ───────────────────────────────────────────────────────────────────

# Host port for the web app container. OPTIONAL.
WEB_PORT=3000


# ── GitHub Container Registry ─────────────────────────────────────────────────

# Your GitHub repo in owner/repo format. Used by docker-compose to pull
# pre-built images from GHCR instead of building locally.
# Leave commented out to always build from source.
# GITHUB_REPOSITORY=your-username/agent-wiki
