{
  "name": "agent-wiki",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter mcp dev\"",
    "build": "pnpm --filter web build && pnpm --filter mcp build",
    "start": "concurrently \"pnpm --filter web start\" \"pnpm --filter mcp start\"",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
