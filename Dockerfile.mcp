# syntax=docker/dockerfile:1
FROM oven/bun:1.3.12-alpine AS base

# ── Dependencies ──────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app
COPY package.json bun.lock ./
COPY apps/mcp/package.json ./apps/mcp/
COPY packages/wiki/package.json ./packages/wiki/
RUN bun install --frozen-lockfile

# ── Builder ───────────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/mcp/node_modules ./apps/mcp/node_modules
COPY --from=deps /app/packages/wiki/node_modules ./packages/wiki/node_modules
COPY package.json bun.lock ./
COPY packages/wiki ./packages/wiki
COPY apps/mcp ./apps/mcp

RUN bun run --filter @agent-wiki/wiki build
WORKDIR /app/apps/mcp
RUN bun run build

# ── Runner ────────────────────────────────────────────────────────────────────
FROM oven/bun:1.3.12-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV MCP_PORT=3001
ENV WIKI_DIR=/wiki

# su-exec: drop privileges from root to app user inside entrypoint
RUN apk add --no-cache su-exec

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 mcpuser

# Runtime files
COPY --from=builder --chown=mcpuser:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=mcpuser:nodejs /app/packages/wiki ./packages/wiki
# compiled output and package.json (needed for "type": "module")
COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/dist ./dist
COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/package.json ./package.json

# Entrypoint: runs as root, fixes /wiki permissions, then drops to mcpuser
COPY docker/entrypoint-mcp.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3001

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bun", "dist/index.js"]
