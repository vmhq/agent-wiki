# syntax=docker/dockerfile:1
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# ── Dependencies ──────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml ./
COPY apps/mcp/package.json ./apps/mcp/
RUN pnpm install --frozen-lockfile --filter mcp

# ── Builder ───────────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/mcp/node_modules ./apps/mcp/node_modules
COPY package.json pnpm-workspace.yaml ./
COPY apps/mcp ./apps/mcp

WORKDIR /app/apps/mcp
RUN pnpm build

# ── Runner ────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV MCP_PORT=3001
ENV WIKI_DIR=/wiki

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 mcpuser

COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/dist ./dist
COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/node_modules ./node_modules
COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/package.json ./package.json

USER mcpuser
EXPOSE 3001

CMD ["node", "dist/index.js"]
