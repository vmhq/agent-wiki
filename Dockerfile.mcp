# syntax=docker/dockerfile:1
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# ── Dependencies ──────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/mcp/package.json ./apps/mcp/
RUN pnpm install --frozen-lockfile --filter mcp...

# ── Builder ───────────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/mcp/node_modules ./apps/mcp/node_modules
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/mcp ./apps/mcp

WORKDIR /app/apps/mcp
RUN pnpm build

# Use pnpm deploy to create a self-contained directory with flattened
# node_modules — avoids missing packages from root-level hoisting
WORKDIR /app
RUN pnpm deploy --filter mcp --prod /deploy

# ── Runner ────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV MCP_PORT=3001
ENV WIKI_DIR=/wiki

# su-exec: drop privileges from root to app user inside entrypoint
RUN apk add --no-cache su-exec

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 mcpuser

# node_modules from pnpm deploy (properly flattened, no symlinks to pnpm store)
COPY --from=builder --chown=mcpuser:nodejs /deploy/node_modules ./node_modules
# compiled output and package.json (needed for "type": "module")
COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/dist ./dist
COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/package.json ./package.json

# Entrypoint: runs as root, fixes /wiki permissions, then drops to mcpuser
COPY docker/entrypoint-mcp.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3001

ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "dist/index.js"]
